			@iconCard("Filter", icons.Filter())
			@iconCard("Flag", icons.Flag())
			@iconCard("Flask", icons.Flask())
			@iconCard("Folder", icons.Folder())
			@iconCard("FolderL", icons.FolderL())
			@iconCard("Gobl", icons.Gobl())
			@iconCard("Handshake", icons.Handshake())
			@iconCard("Hashtag", icons.Hashtag())
			@iconCard("Header", icons.Header())
			@iconCard("History", icons.History())
			@iconCard("IdBack", icons.IdBack())
			@iconCard("IdFront", icons.IdFront())
			@iconCard("Info", icons.Info())
			@iconCard("InfoBold", icons.InfoBold())
			@iconCard("Invoice", icons.Invoice())
			@iconCard("Invopop", icons.Invopop())
			@iconCard("Key", icons.Key())
			@iconCard("Learn", icons.Learn())
			@iconCard("List", icons.List())
			@iconCard("Loader", icons.Loader())
			@iconCard("Lock", icons.Lock())
			@iconCard("Logout", icons.Logout())
			@iconCard("Menu", icons.Menu())
			@iconCard("Note", icons.Note())
			@iconCard("Notification", icons.Notification())
			@iconCard("Options", icons.Options())
			@iconCard("Order", icons.Order())
			@iconCard("Payment", icons.Payment())
			@iconCard("Pin", icons.Pin())
			@iconCard("Placeholder", icons.Placeholder())
			@iconCard("Pops", icons.Pops())
			@iconCard("Preview", icons.Preview())
			@iconCard("Puzzle", icons.Puzzle())
			@iconCard("Question", icons.Question())
			@iconCard("Queue", icons.Queue())
			@iconCard("Receipt", icons.Receipt())
			@iconCard("Reload", icons.Reload())
			@iconCard("Replace", icons.Replace())
			@iconCard("Reset", icons.Reset())
			@iconCard("Rocket", icons.Rocket())
			@iconCard("Running", icons.Running())
			@iconCard("Save", icons.Save())
