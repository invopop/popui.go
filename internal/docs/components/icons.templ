			@iconCard("Command", icons.Command())
			@iconCard("Community", icons.Community())
			@iconCard("Company", icons.Company())
			@iconCard("Conditions", icons.Conditions())
			@iconCard("Connect", icons.Connect())
			@iconCard("CrumpledPaper", icons.CrumpledPaper())
			@iconCard("Cube", icons.Cube())
			@iconCard("Dashboard", icons.Dashboard())
			@iconCard("Delete", icons.Delete())
			@iconCard("DoubleArrow", icons.DoubleArrow())
			@iconCard("Download", icons.Download())
			@iconCard("Drag", icons.Drag())
			@iconCard("DropdownDown", icons.DropdownDown())
			@iconCard("DropdownUp", icons.DropdownUp())
			@iconCard("Duplicate", icons.Duplicate())
			@iconCard("Edit", icons.Edit())
			@iconCard("Enter", icons.Enter())
