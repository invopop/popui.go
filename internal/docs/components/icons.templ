			@iconCard("Block", icons.Block())
			@iconCard("Bot", icons.Bot())
			@iconCard("Box", icons.Box())
			@iconCard("Brackets", icons.Brackets())
			@iconCard("Calculator", icons.Calculator())
			@iconCard("Calendar", icons.Calendar())
			@iconCard("CheckBadge", icons.CheckBadge())
			@iconCard("CheckCircle", icons.CheckCircle())
			@iconCard("ChevronDown", icons.ChevronDown())
			@iconCard("ChevronLeft", icons.ChevronLeft())
			@iconCard("ChevronRight", icons.ChevronRight())
			@iconCard("ChevronUp", icons.ChevronUp())
			@iconCard("CircleOutline", icons.CircleOutline())
			@iconCard("Close", icons.Close())
