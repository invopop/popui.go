package examples

import (
	"github.com/invopop/popui.go"
	"github.com/invopop/popui.go/props"
)

templ MultiselectDisabledExample() {
	@popui.Multiselect(props.Multiselect{
		Name:     "countries",
		Disabled: true,
		Options: []props.MultiselectOption{
			{Value: "es", Label: "Spain", Selected: true},
			{Value: "fr", Label: "France", Selected: true},
			{Value: "de", Label: "Germany"},
		},
	})
}
