package examples

import (
	"github.com/invopop/popui.go"
	"github.com/invopop/popui.go/props"
)

templ SkeletonSizesExample() {
	<div class="flex flex-col gap-3 w-64">
		@popui.Loading(props.Loading{Size: props.LoadingSizeXS})
		@popui.Loading(props.Loading{Size: props.LoadingSizeSmall})
		@popui.Loading(props.Loading{Size: props.LoadingSizeMedium})
		@popui.Loading(props.Loading{Size: props.LoadingSizeLarge})
		@popui.Loading(props.Loading{Size: props.LoadingSizeXL})
	</div>
}
