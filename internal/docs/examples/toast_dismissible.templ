package examples

import (
	"github.com/invopop/popui.go"
	"github.com/invopop/popui.go/props"
)

templ ToastDismissibleExample() {
	@popui.Toast(props.Toast{
		Title:       "Dismissible Toast",
		Description: "Click the X button to dismiss this notification.",
		Dismissible: true,
		Icon:        true,
	})
}
