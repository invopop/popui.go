package examples

import (
	"github.com/invopop/popui.go"
	"github.com/invopop/popui.go/props"
)

templ ToastWithIconExample() {
	// With icon and description
	@popui.Toast(props.Toast{
		Variant:     "success",
		Title:       "Invoice sent",
		Description: "The invoice has been sent to the customer.",
		Icon:        true,
	})
	// With icon, no description (icon centers with title)
	@popui.Toast(props.Toast{
		Variant:     "error",
		Title:       "Payment failed",
		Icon:        true,
	})
}
