package examples

import (
	"github.com/invopop/popui.go"
	"github.com/invopop/popui.go/props"
)

templ TypographyTitleGroupExample() {
	<div class="flex flex-col gap-6">
		@popui.TitleGroup(props.TitleGroup{
			Title:       "Categories",
			Description: "Select all that apply",
		})
		@popui.TitleGroup(props.TitleGroup{
			Title:       "Categories",
			Description: "Select all that apply",
			Horizontal:  true,
		})
	</div>
}
