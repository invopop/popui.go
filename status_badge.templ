package popui

import (
	"github.com/invopop/icons"
	"github.com/invopop/popui.go/props"
	"github.com/invopop/popui.go/tailwind"
)

// StatusBadge provides a status tag with a leading status icon and an optional label.
// Supports status variants: success, failed, warning, running
templ StatusBadge(p ...props.StatusBadge) {
	{{ prp := props.First(p) }}
	<span
		if prp.ID != "" {
			id={ prp.ID }
		}
		class={ tailwind.Merge(
			"inline-flex items-center gap-1 rounded-full bg-background-default-secondary h-5 px-1",
			prp.Class,
		) }
		{ prp.Attributes... }
	>
		<span data-status-badge-icon class="shrink-0">
			switch prp.Status {
				case "failed":
					@icons.Failure()
				case "warning":
					@icons.Warning()
				case "running":
					@icons.Running()
				default:
					@icons.Success()
			}
		</span>
		if prp.Label != "" {
			<span data-status-badge-label class="font-sans text-sm font-medium text-foreground">{ prp.Label }</span>
		}
	</span>
}
